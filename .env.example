# AWS Bedrock credentials
AWS_REGION=us-east-2
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here

# Path to TIQ World codebase on your machine
TIQ_CODEBASE_PATH=C:/Users/Shalini Mishra/TIQ

# PostgreSQL connection for db_query tool
# Requires SSM tunnel running: ssh -L 5433:rds-host:5432 bastion
# Format: postgresql://user:password@localhost:5433/dbname
DB_URL=postgresql://postgres:password@localhost:5433/tiqworld

# Web UI port (default: 3001) — run with: npm run web
WEB_PORT=3001

# Bedrock prompt caching — reduces token cost ~60% on long sessions
# Set to true to enable (requires Bedrock prompt caching support in your region)
ENABLE_PROMPT_CACHE=false

# Auto maintenance scan interval in minutes (0 = run once at startup only)
# Example: SCAN_INTERVAL_MINUTES=30 runs a full scan every 30 minutes
SCAN_INTERVAL_MINUTES=0
